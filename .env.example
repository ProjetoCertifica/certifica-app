VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Recall.ai — obtenha em app.recall.ai → API Keys
RECALL_API_TOKEN=your-recall-api-token
RECALL_REGION=us-west-2

# Google OAuth para integração do Calendário (Calendar V1)
# Crie em console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# URI de redirecionamento autorizada: https://us-west-2.recall.ai/api/v1/calendar/google_oauth_callback/
# Configure também em app.recall.ai → Settings → Calendar Integration
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
